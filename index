<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dashboard รายการรถเช่า (จำนวนรถ/จังหวัด)</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Segoe UI', Tahoma, sans-serif; background: #0f172a; color: #e2e8f0; min-height: 100vh; }

  header {
    background: linear-gradient(135deg, #f5f5f0 0%, #ffffff 60%, #eef2ff 100%);
    padding: 14px 32px;
    display: flex; align-items: center; gap: 16px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.15);
    border-bottom: 3px solid #1e40af;
  }
  header .icon { font-size: 36px; }
  header h1 { font-size: 22px; font-weight: 700; color: #1e3a8a; letter-spacing: 0.5px; }
  header p { font-size: 13px; color: #3b82f6; font-weight: 500; }

  .container { max-width: 1200px; margin: 0 auto; padding: 20px; }

  .kpi-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 16px; margin-bottom: 24px;
  }
  .kpi-card {
    background: #1e293b; padding: 20px; border-radius: 16px;
    border: 1px solid #334155; text-align: center;
  }
  .kpi-card h3 { font-size: 14px; color: #94a3b8; margin-bottom: 8px; text-transform: uppercase; }
  .kpi-card .value { font-size: 28px; font-weight: 800; color: #f8fafc; }

  .chart-section {
    background: #1e293b; padding: 24px; border-radius: 20px;
    border: 1px solid #334155; margin-bottom: 24px;
  }
  .chart-container { height: 300px; position: relative; }

  .controls {
    display: grid; grid-template-columns: 1fr auto auto; gap: 12px; margin-bottom: 20px;
  }
  input, select {
    background: #1e293b; border: 1px solid #334155; color: white;
    padding: 12px 16px; border-radius: 12px; outline: none;
  }

  .card-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 16px;
  }
  .card {
    background: #1e293b; border-radius: 16px; padding: 16px;
    border: 1px solid #334155; transition: 0.2s; cursor: pointer;
  }
  .card:hover { transform: translateY(-4px); border-color: #3b82f6; }
  .card-header { display: flex; justify-content: space-between; margin-bottom: 12px; }
  .badge { padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: bold; }
  .badge-new { background: #065f46; color: #34d399; }
  .badge-used { background: #92400e; color: #fbbf24; }
  
  .model-name { font-size: 18px; font-weight: 700; margin-bottom: 4px; color: #f8fafc; }
  .company-name { font-size: 14px; color: #94a3b8; margin-bottom: 12px; }
  
  .info-row { display: flex; justify-content: space-between; font-size: 13px; margin-bottom: 6px; }
  .label { color: #64748b; }
</style>
</head>
<body>

<header>
  <div class="icon">🚜</div>
  <div>
    <h1>Rental Fleet Dashboard</h1>
    <p>สถิติจำนวนรถแยกตามจังหวัดและรุ่น</p>
  </div>
</header>

<div class="container">
  <div class="kpi-grid" id="kpiGrid">
    <div class="kpi-card"><h3>จำนวนรถทั้งหมด</h3><div class="value" id="totalUnits">-</div></div>
    <div class="kpi-card"><h3>จังหวัดที่มีรถมากสุด</h3><div class="value" id="topProvince">-</div></div>
    <div class="kpi-card"><h3>รุ่นยอดนิยม</h3><div class="value" id="topModel">-</div></div>
  </div>

  <div class="chart-section">
    <h2 style="margin-bottom:16px; font-size:18px;">📊 จำนวนรถแยกตามจังหวัด (ยูนิต)</h2>
    <div class="chart-container">
      <canvas id="provinceChart"></canvas>
    </div>
  </div>

  <div class="controls">
    <input type="text" id="searchInput" placeholder="ค้นหาบริษัท หรือ รุ่นรถ..." oninput="updateUI()">
    <select id="provinceFilter" onchange="updateUI()"><option value="">ทุกจังหวัด</option></select>
    <select id="modelFilter" onchange="updateUI()"><option value="">ทุกรุ่น</option></select>
  </div>

  <div class="card-grid" id="cardContainer"></div>
</div>

<script>
// --- CONFIG: ใส่ SHEET_ID ของคุณตรงนี้ ---
const SHEET_ID = '1iFWpgZBXHa93M6iTlI5Xce4jTJVEy374tBDtHMKyCZI'; 
let RAW_DATA = [];
let myChart = null;

async function loadFromSheet() {
  const url = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:json`;
  try {
    const response = await fetch(url);
    const text = await response.text();
    const json = JSON.parse(text.replace(/^[\s\S]*?setResponse\(/, '').replace(/\);?\s*$/, ''));
    
    const rows = json.table.rows;
    const cols = json.table.cols;
    
    RAW_DATA = rows.map(row => {
      let obj = {};
      row.c.forEach((cell, i) => {
        if (cols[i].label) obj[cols[i].label] = cell ? cell.v : '';
      });
      return obj;
    });

    initFilters();
    updateUI();
  } catch (e) {
    console.error("Error:", e);
    document.getElementById('cardContainer').innerHTML = "เชื่อมต่อข้อมูลไม่ได้ กรุณาตรวจสอบการแชร์ไฟล์ Google Sheet";
  }
}

function initFilters() {
  const provinces = [...new Set(RAW_DATA.map(d => d.province))].filter(Boolean);
  const models = [...new Set(RAW_DATA.map(d => d.model))].filter(Boolean);
  
  const pSelect = document.getElementById('provinceFilter');
  provinces.forEach(p => pSelect.innerHTML += `<option value="${p}">${p}</option>`);
  
  const mSelect = document.getElementById('modelFilter');
  models.forEach(m => mSelect.innerHTML += `<option value="${m}">${m}</option>`);
}

function updateUI() {
  const searchTerm = document.getElementById('searchInput').value.toLowerCase();
  const pFilter = document.getElementById('provinceFilter').value;
  const mFilter = document.getElementById('modelFilter').value;

  const filtered = RAW_DATA.filter(d => {
    const matchSearch = (d.company?.toLowerCase().includes(searchTerm)) || (d.model?.toLowerCase().includes(searchTerm));
    const matchProvince = !pFilter || d.province === pFilter;
    const matchModel = !mFilter || d.model === mFilter;
    return matchSearch && matchProvince && matchModel;
  });

  renderCards(filtered);
  updateKPIs(filtered);
  updateChart(filtered);
}

function updateKPIs(data) {
  document.getElementById('totalUnits').innerText = data.length.toLocaleString() + ' คัน';
  
  // หาจังหวัดที่มีรถเยอะสุด
  const pCount = {};
  data.forEach(d => pCount[d.province] = (pCount[d.province] || 0) + 1);
  const topP = Object.entries(pCount).sort((a,b) => b[1]-a[1])[0];
  document.getElementById('topProvince').innerText = topP ? topP[0] : '-';

  // หารุ่นยอดนิยม
  const mCount = {};
  data.forEach(d => mCount[d.model] = (mCount[d.model] || 0) + 1);
  const topM = Object.entries(mCount).sort((a,b) => b[1]-a[1])[0];
  document.getElementById('topModel').innerText = topM ? topM[0] : '-';
}

function updateChart(data) {
  const pData = {};
  data.forEach(d => {
    if(d.province) pData[d.province] = (pData[d.province] || 0) + 1;
  });

  const labels = Object.keys(pData);
  const counts = Object.values(pData);

  const ctx = document.getElementById('provinceChart').getContext('2d');
  
  if (myChart) myChart.destroy();

  myChart = new Chart(ctx, {
    type: 'bar',
    data: {
      labels: labels,
      datasets: [{
        label: 'จำนวนรถ (คัน)',
        data: counts,
        backgroundColor: '#3b82f6',
        borderRadius: 8
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: {
        y: { beginAtZero: true, grid: { color: '#334155' }, ticks: { color: '#94a3b8' } },
        x: { grid: { display: false }, ticks: { color: '#94a3b8' } }
      }
    }
  });
}

function renderCards(data) {
  const container = document.getElementById('cardContainer');
  container.innerHTML = data.map(d => `
    <div class="card">
      <div class="card-header">
        <span class="badge ${d.new_used === 'NEW' ? 'badge-new' : 'badge-used'}">${d.new_used}</span>
        <span style="color:#64748b; font-size:12px;">${d.province}</span>
      </div>
      <div class="model-name">${d.model || 'Unknown Model'}</div>
      <div class="company-name">${d.company || 'ไม่ระบุชื่อบริษัท'}</div>
      <div class="info-row">
        <span class="label">สัญญาเริ่ม:</span>
        <span>${d.start || '-'}</span>
      </div>
      <div class="info-row">
        <span class="label">ราคาเช่า:</span>
        <span style="color:#4ade80; font-weight:bold;">${d.price?.toLocaleString() || '0'} ฿</span>
      </div>
    </div>
  `).join('');
}

window.onload = loadFromSheet;
</script>

</body>
</html>
